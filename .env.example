# Paramod backend (server-only)
BACKEND_URL=http://localhost:8888/api/v1/

# Ghost CMS (server-only). Optional: set NEXT_PUBLIC_GHOST_BASE_URL for image URLs in GhostStory.
GHOST_URL=http://213.131.1.29
# Вариант 1: старый API v0.1 (client_id + client_secret)
GHOST_CLIENT_ID=ghost-frontend
GHOST_CLIENT_SECRET=
# Вариант 2: Content API v3 (один ключ из админки Ghost)
GHOST_CONTENT_API_KEY=

# Optional: base URL for Ghost content images (client-visible)
# NEXT_PUBLIC_GHOST_BASE_URL=http://213.131.1.29
